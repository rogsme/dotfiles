{
  "$schema": "https://opencode.ai/config.json",
  "theme": "everforest",
  "model": "anthropic/claude-sonnet-4-5-20250929",
  "plugin": [
    "opencode-anthropic-auth@latest"
  ],
  "tools": {
    "webfetch": true
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp", "--api-key", "${CONTEXT7_API_KEY}"],
      "enabled": false
    },
    "pal-mcp": {
      "type": "local",
      "command": [
        "/home/roger/.config/opencode/pal-mcp-server/.pal_venv/bin/python",
        "/home/roger/.config/opencode/pal-mcp-server/server.py"
      ],
      "enabled": true
    },
    "jira": {
      "type": "local",
      "command": ["npx", "-y", "mcp-remote", "https://mcp.atlassian.com/v1/sse"],
      "enabled": false
    }
  },
  "provider": {
    "lazer": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Lazer",
      "options": {
        "baseURL": "https://llm.lazertechnologies.com/v1"
      },
      "models": {
        "gemini/gemini-2.0-flash": { "name": "Gemini 2.0 Flash" },
        "gemini/gemini-2.5-flash": { "name": "Gemini 2.5 Flash" },
        "gemini/gemini-2.5-pro": { "name": "Gemini 2.5 Pro" },
        "gemini/gemini-3.1-pro-preview": { "name": "Gemini 3.1 Pro Preview" },
        "gemini/gemini-3-flash-preview": { "name": "Gemini 3 Flash Preview" },
        "xai/grok-code-fast-1": { "name": "Grok Code Fast" },
        "anthropic/claude-sonnet-4-6": { "name": "Claude Sonnet 4.6" },
        "anthropic/claude-haiku-4-5": { "name": "Claude 4.5 Haiku" },
        "anthropic/claude-opus-4-6": { "name": "Claude 4.6 Opus" },
        "openai/gpt-5.3-codex": { "name": "GPT 5.3 Codex" },
        "deepinfra/MiniMaxAI/MiniMax-M2.5": { "name": "MiniMax-M2.5" },
        "deepinfra/moonshotai/Kimi-K2.5": { "name": "Kimi K2.5" }
      }
    }
  },
  "keybinds": {
    "leader": "ctrl+x",
    "app_exit": "ctrl+c,<leader>q",
    "editor_open": "<leader>e",
    "theme_list": "<leader>t"
  }
}
