{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "agent": {
    "plan": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "xhigh"
    },
    "build": {
      "model": "openai/gpt-5.3-codex",
      "reasoningEffort": "xhigh"
    }
  },
  "tools": {
    "webfetch": true
  },
  "instructions": [
    "~/.config/opencode/instructions/shell-strategy/shell_strategy.md"
  ],
  "provider": {
    "lazer": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Lazer",
      "options": {
        "baseURL": "https://llm.lazertechnologies.com/v1"
      },
      "models": {
        "deepinfra/MiniMaxAI/MiniMax-M2.5": {
          "name": "MiniMax-M2.5",
          "reasoning": true
        },
        "deepinfra/Qwen/Qwen3-235B-A22B-Thinking-2507": {
          "name": "Qwen3 235B Thinking 2507",
          "reasoning": true
        },
        "deepinfra/Qwen/Qwen3-Coder-480B-A35B-Instruct-Turbo": {
          "name": "Qwen3 Coder 480B Instruct Turbo"
        },
        "deepinfra/moonshotai/Kimi-K2.5-Turbo": {
          "name": "Kimi K2.5 Turbo",
          "reasoning": true
        },
        "deepinfra/openai/gpt-oss-120b-Turbo": {
          "name": "GPT OSS 120B Turbo",
          "reasoning": true
        },
        "deepinfra/zai-org/GLM-5": {
          "name": "GLM-5",
          "reasoning": true
        },
        "gemini/gemini-3-flash-preview": {
          "name": "Gemini 3 Flash Preview",
          "reasoning": true
        },
        "gemini/gemini-3.1-pro-preview": {
          "name": "Gemini 3.1 Pro Preview",
          "reasoning": true
        },
        "openai/gpt-5.3-codex": {
          "name": "GPT-5.3 Codex",
          "reasoning": true,
          "variants": {
            "none": {
              "reasoningEffort": "none"
            },
            "minimal": {
              "reasoningEffort": "minimal"
            },
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "high": {
              "reasoningEffort": "high"
            },
            "xhigh": {
              "reasoningEffort": "xhigh"
            }
          }
        },
        "openai/gpt-5.4": {
          "name": "GPT-5.4",
          "reasoning": true,
          "variants": {
            "none": {
              "reasoningEffort": "none"
            },
            "minimal": {
              "reasoningEffort": "minimal"
            },
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "high": {
              "reasoningEffort": "high"
            },
            "xhigh": {
              "reasoningEffort": "xhigh"
            }
          }
        },
        "openai/gpt-5.4-mini": {
          "name": "GPT-5.4 mini",
          "reasoning": true,
          "variants": {
            "none": {
              "reasoningEffort": "none"
            },
            "minimal": {
              "reasoningEffort": "minimal"
            },
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "high": {
              "reasoningEffort": "high"
            },
            "xhigh": {
              "reasoningEffort": "xhigh"
            }
          }
        }
      }
    }
  },
  "keybinds": {
    "leader": "ctrl+x",
    "app_exit": "ctrl+c,<leader>q",
    "editor_open": "<leader>e",
    "theme_list": "<leader>t"
  },
  "plugin": [
    "opentmux",
    "opencode-scheduler"
  ],
  "permission": {
    "read": {
      "~/.config/opencode/get-shit-done/*": "allow"
    },
    "external_directory": {
      "~/.config/opencode/get-shit-done/*": "allow"
    }
  }
}
