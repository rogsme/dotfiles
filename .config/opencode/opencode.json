{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "agent": {
    "plan": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "high"
    },
    "build": {
      "model": "openai/gpt-5.3-codex",
      "reasoningEffort": "high"
    }
  },
  "tools": {
    "webfetch": true
  },
  "instructions": [
    "~/.config/opencode/instructions/shell-strategy/shell_strategy.md"
  ],
  "provider": {
    "lazer": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Lazer",
      "options": {
        "baseURL": "https://llm.lazertechnologies.com/v1"
      },
      "models": {
        "deepinfra/MiniMaxAI/MiniMax-M2.5": {
          "name": "MiniMax-M2.5"
        },
        "deepinfra/Qwen/Qwen3-235B-A22B-Instruct-2507": {
          "name": "Qwen3 235B Instruct 2507"
        },
        "deepinfra/Qwen/Qwen3-235B-A22B-Thinking-2507": {
          "name": "Qwen3 235B Thinking 2507"
        },
        "deepinfra/Qwen/Qwen3-Coder-480B-A35B-Instruct": {
          "name": "Qwen3 Coder 480B Instruct"
        },
        "deepinfra/Qwen/Qwen3-Coder-480B-A35B-Instruct-Turbo": {
          "name": "Qwen3 Coder 480B Instruct Turbo"
        },
        "deepinfra/deepseek-ai/DeepSeek-V3.2": {
          "name": "DeepSeek V3.2"
        },
        "deepinfra/moonshotai/Kimi-K2.5": {
          "name": "Kimi K2.5"
        },
        "deepinfra/openai/gpt-oss-120b": {
          "name": "GPT OSS 120B"
        },
        "deepinfra/openai/gpt-oss-120b-Turbo": {
          "name": "GPT OSS 120B Turbo"
        },
        "deepinfra/zai-org/GLM-5": {
          "name": "GLM-5"
        },
        "gemini/gemini-2.0-flash": {
          "name": "Gemini 2.0 Flash"
        },
        "gemini/gemini-2.5-flash": {
          "name": "Gemini 2.5 Flash"
        },
        "gemini/gemini-2.5-pro": {
          "name": "Gemini 2.5 Pro"
        },
        "gemini/gemini-3-flash-preview": {
          "name": "Gemini 3 Flash Preview"
        },
        "gemini/gemini-3.1-pro-preview": {
          "name": "Gemini 3.1 Pro Preview"
        },
        "openai/gpt-5.3-codex": {
          "name": "GPT 5.3 Codex"
        },
        "openai/gpt-5.4": {
          "name": "GPT 5.4"
        },
        "xai/grok-code-fast-1": {
          "name": "Grok Code Fast"
        }
      }
    }
  },
  "keybinds": {
    "leader": "ctrl+x",
    "app_exit": "ctrl+c,<leader>q",
    "editor_open": "<leader>e",
    "theme_list": "<leader>t"
  },
  "plugin": [
    "opentmux",
    "opencode-scheduler"
  ],
  "permission": {
    "read": {
      "~/.config/opencode/get-shit-done/*": "allow"
    },
    "external_directory": {
      "~/.config/opencode/get-shit-done/*": "allow"
    }
  }
}
