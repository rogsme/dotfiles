{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "system",
  "scroll_speed": 1,
  "scroll_acceleration": {
    "enabled": false
  },
  "keybinds": {
    "leader": "ctrl+x",
    "app_exit": "ctrl+c,<leader>q",
    "editor_open": "<leader>e",
    "theme_list": "<leader>t"
  },
  "plugin": [
    "@prevalentware/opencode-goal-plugin"
  ]
}
