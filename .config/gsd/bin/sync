#!/usr/bin/env bash
# Symlink every canonical skill into ~/.claude/skills/.
# Symlinks (not copies) make drift structurally impossible.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TARGET="$HOME/.claude/skills"
mkdir -p "$TARGET"

status=0
for src in "$ROOT"/skills/gsd-*/; do
  name="$(basename "$src")"
  dest="$TARGET/$name"
  if [[ -e "$dest" && ! -L "$dest" ]]; then
    echo "REFUSED  $name — $dest is a real directory (stock GSD leftover?). Remove it first."
    status=1
    continue
  fi
  ln -sfn "${src%/}" "$dest"
  echo "LINKED   $name"
done

exit $status
